# Choose any subset — Praxia auto-detects which provider to use.

# Anthropic Claude (recommended for complex reasoning)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ChatGPT
# OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Alibaba Qwen via DashScope (cloud API)
# DASHSCOPE_API_KEY=...

# Qwen / Llama / etc. via Ollama (local)
# Set OLLAMA_API_BASE only if not using the default localhost:11434
# OLLAMA_API_BASE=http://localhost:11434

# OpenRouter (multi-provider gateway)
# OPENROUTER_API_KEY=...

# --- Memory backend selection -------------------------------------------------
# "json" (default, no extra deps), "mem0", "langmem", "letta", "zep"
# PRAXIA_MEMORY_BACKEND=mem0

# --- Optional: Mem0 backend embedding/storage configuration ------------------
# OPENAI_API_KEY (already above) is used by Mem0 for embeddings by default
# QDRANT_URL=http://localhost:6333  (if you want a real vector store)
