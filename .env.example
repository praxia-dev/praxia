# Praxia configuration — canonical key reference
# Copy this file to `.env` and fill in only the keys you actually use.
#
# Resolution order (first match wins):
#   1. Process environment variables
#   2. .env file (this file)
#   3. .praxia/config.toml (managed by `praxia config set`)
#
# Run `praxia config show` to see what's currently resolved.
# Run `praxia config init` for an interactive walkthrough.

# ============================================================================
# LLM providers — set at least ONE of the following
# ============================================================================

# Anthropic Claude (recommended — best for reasoning, long-form output)
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI ChatGPT — also enables Whisper STT and OpenAI TTS for voice I/O
# OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Alibaba Qwen via DashScope (cloud API)
# DASHSCOPE_API_KEY=...

# OpenRouter (multi-provider gateway)
# OPENROUTER_API_KEY=...

# Qwen / Llama via Ollama (local, no API key needed — set to override default)
# OLLAMA_API_BASE=http://localhost:11434

# ============================================================================
# Memory backend selection
# ============================================================================

# json (default, no extra deps), mem0, langmem, letta, zep, hindsight
# PRAXIA_MEMORY_BACKEND=mem0

# Optional: vector-store endpoint for the chosen backend
# QDRANT_URL=http://localhost:6333

# ============================================================================
# Authentication / token encryption
# ============================================================================

# JWT signing secret — generate a strong random value for production
# PRAXIA_JWT_SECRET=replace-with-strong-random-secret

# Encryption key for OAuth tokens at rest — separate from JWT secret
# PRAXIA_TOKEN_ENC_KEY=replace-with-different-strong-random-secret

# ============================================================================
# SSO (federated authentication for the Praxia portal — optional)
# ============================================================================

# Provider: google | microsoft | okta | github | keycloak | custom_oidc
# PRAXIA_SSO_PROVIDER=google
# PRAXIA_SSO_CLIENT_ID=...
# PRAXIA_SSO_CLIENT_SECRET=...
# PRAXIA_SSO_REDIRECT_URI=https://praxia.example.com/auth/callback

# Provider-specific (set as required):
# PRAXIA_SSO_TENANT_ID=...                  # Microsoft Entra ID
# PRAXIA_SSO_OKTA_DOMAIN=acme.okta.com      # Okta
# PRAXIA_SSO_KEYCLOAK_BASE_URL=https://kc.example.com
# PRAXIA_SSO_KEYCLOAK_REALM=praxia
# PRAXIA_SSO_ISSUER_URL=https://idp.example.com  # Generic OIDC

# ============================================================================
# User-delegated OAuth for connectors (recommended for enterprise)
# Each Praxia user authorizes external systems with their own credentials.
# Register an OAuth app at each provider and put credentials below.
# ============================================================================

# PRAXIA_OAUTH_BOX_CLIENT_ID=...
# PRAXIA_OAUTH_BOX_CLIENT_SECRET=...

# PRAXIA_OAUTH_MICROSOFT_CLIENT_ID=...
# PRAXIA_OAUTH_MICROSOFT_CLIENT_SECRET=...

# PRAXIA_OAUTH_DROPBOX_CLIENT_ID=...
# PRAXIA_OAUTH_DROPBOX_CLIENT_SECRET=...

# PRAXIA_OAUTH_GOOGLE_CLIENT_ID=...
# PRAXIA_OAUTH_GOOGLE_CLIENT_SECRET=...

# PRAXIA_OAUTH_SALESFORCE_CLIENT_ID=...
# PRAXIA_OAUTH_SALESFORCE_CLIENT_SECRET=...

# ============================================================================
# Shared-credential connectors (legacy / service account fallback)
# Used only when you DON'T set up per-user OAuth. Pattern:
#   PRAXIA_CONN_<UPPERCASE_NAME>_<UPPERCASE_KEY>
# ============================================================================

# Box (single shared service account)
# PRAXIA_CONN_BOX_ACCESS_TOKEN=...
# PRAXIA_CONN_BOX_CLIENT_ID=...
# PRAXIA_CONN_BOX_CLIENT_SECRET=...

# kintone (no OAuth flow available — API token only)
# PRAXIA_CONN_KINTONE_SUBDOMAIN=acme
# PRAXIA_CONN_KINTONE_API_TOKEN=...

# Salesforce (legacy username/password+token path)
# PRAXIA_CONN_SALESFORCE_USERNAME=admin@acme.com
# PRAXIA_CONN_SALESFORCE_PASSWORD=...
# PRAXIA_CONN_SALESFORCE_SECURITY_TOKEN=...

# ============================================================================
# Audio I/O (optional — set when using STT / TTS)
# ============================================================================

# OpenAI provides both Whisper STT and TTS — uses OPENAI_API_KEY above.
# ElevenLabs (premium TTS, voice cloning):
# ELEVENLABS_API_KEY=...
